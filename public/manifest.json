{
  "manifest_version": 3,
  "name": "Personal JioHotstar Curator",
  "description": "Hide unwanted titles, track watched content, and build a cleaner JioHotstar discovery flow.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://*.hotstar.com/*", "https://*.jiohotstar.com/*"],
  "background": {
    "service_worker": "extension/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "JioHotstar Curator",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.hotstar.com/*", "https://*.jiohotstar.com/*"],
      "js": ["extension/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://*.hotstar.com/*", "https://*.jiohotstar.com/*"]
    }
  ]
}

