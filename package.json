{
  "name": "personal-jiohotstar-curator",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:content": "node ./scripts/build-content.mjs",
    "build": "tsc -b && vite build && node ./scripts/build-content.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "security:scan": "node ./scripts/security/scan-secrets.mjs",
    "verify": "npm test && npm run build && npm run security:scan",
    "catalog:seed": "node --env-file=.env ./scripts/catalog/build-catalog.mjs",
    "catalog:tmdb": "node --env-file=.env ./scripts/catalog/build-tmdb-catalog.mjs"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "dexie": "^4.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chrome": "^0.1.24",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
